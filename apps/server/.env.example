# 서버 환경변수

# ── Supabase (PostgreSQL) ──────────────────────────────────────────
# Supabase 프로젝트 → Settings → Database → Connection string → URI
# Transaction mode (포트 6543) — Prisma 일반 쿼리용
DATABASE_URL="postgresql://postgres.mxradtrcxtpzbaynnmye:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection (포트 5432) — prisma migrate dev 전용
DIRECT_URL="postgresql://postgres.mxradtrcxtpzbaynnmye:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# ── Upstash Redis ──────────────────────────────────────────────────
# Upstash 콘솔 → 데이터베이스 선택 → .env 탭에서 REDIS_URL 복사
REDIS_URL="rediss://:[password]@[endpoint].upstash.io:6380"

# ── 서버 ──────────────────────────────────────────────────────────
PORT=3000
